#!/usr/bin/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# QD-Today 启动脚本 (S6 longrun)
# 在 cont-init.d 完成持久化目录设置后，启动 QD-Today Tornado 应用（前台阻塞）
# ==============================================================================
bashio::log.info "Starting QD-Today..."

# 导出所有配置项为环境变量
# - bool/int 类型: 始终导出（options 默认值即 QD 默认值）
# - str 类型: 仅非空时导出，空字符串由 QD 使用自身内置默认值
# - 高级配置（UI隐藏）: 通过 $2 填默认值，用户手动写入 YAML 时覆盖
_export_str() {
  local key="$1"
  local val
  val="$(bashio::config "${key}")"
  if [ -n "${val}" ]; then
    export "${key}=${val}"
    bashio::log.debug "Configured: ${key}=${val}"
  fi
}

_export_val() {
  local key="$1" default="${2:-}"
  local val
  val="$(bashio::config "${key}" "${default}")"
  export "${key}=${val}"
  bashio::log.debug "Configured: ${key}=${val}"
}

_export_val "QD_DEBUG"
_export_str "AES_KEY"
_export_str "COOKIE_SECRET"
_export_str "DOMAIN"
_export_val "USE_PYCURL" "true"
_export_str "DNS_SERVER"
_export_val "TRACEBACK_PRINT" "false"
_export_val "PUSH_BATCH_SW" "true"
_export_str "PROXIES"
_export_str "MAIL_SMTP"
_export_val "MAIL_PORT"
_export_val "MAIL_SSL" "true"
_export_str "MAIL_USER"
_export_str "MAIL_PASSWORD"
_export_val "TASK_REQUEST_LIMIT" "1500"
_export_val "TASK_WHILE_LOOP_TIMEOUT" "900"
_export_val "NEW_TASK_DELAY" "1"

cd /usr/src/app

# 启动前诊断
bashio::log.info "Python: $(python3 --version 2>&1)"
bashio::log.info "Working dir: $(pwd)"
bashio::log.info "QD source: $(ls run.py config.py 2>&1)"

python3 run.py &
APP_PID=$!
trap 'kill $APP_PID 2>/dev/null; exit 0' TERM INT
bashio::log.info "Waiting for QD-Today to become ready..."
for i in $(seq 1 120); do
    if curl -sf http://127.0.0.1:8923/ 2>/dev/null; then
        bashio::log.info "QD-Today is ready (${i}s)"
        printf '\n' >&3
        wait $APP_PID
        exit $?
    fi
    sleep 1
done
bashio::log.error "QD-Today failed to start within 120s"
kill $APP_PID 2>/dev/null
exit 1
