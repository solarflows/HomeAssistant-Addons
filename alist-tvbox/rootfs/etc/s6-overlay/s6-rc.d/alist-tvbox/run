#!/usr/bin/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# alist-tvbox 启动脚本 (S6 longrun)
# 在 cont-init.d 完成持久化目录设置后，进入 /opt/atv 启动 Spring Boot
# ==============================================================================
bashio::log.info "Starting AList-TvBox..."

cd /opt/atv
/docker/scripts/entrypoint.sh 81 --spring.profiles.active=production,xiaoya &
APP_PID=$!
trap 'kill $APP_PID 2>/dev/null; exit 0' TERM INT
bashio::log.info "Waiting for AList-TvBox to become ready..."
for i in $(seq 1 120); do
    if curl -sf http://127.0.0.1:4567/ 2>/dev/null; then
        bashio::log.info "AList-TvBox is ready (${i}s)"
        wait $APP_PID
        exit $?
    fi
    sleep 1
done
bashio::log.error "AList-TvBox failed to start within 120s"
kill $APP_PID 2>/dev/null
exit 1
