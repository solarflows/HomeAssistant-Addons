#!/usr/bin/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Uptime Kuma 启动脚本 (S6 longrun)
# ==============================================================================
bashio::log.info "Starting Uptime Kuma..."

cd /opt/uptime-kuma || exit 1
node server/server.js &
APP_PID=$!
trap 'kill $APP_PID 2>/dev/null; exit 0' TERM INT
bashio::log.info "Waiting for Uptime Kuma to become ready..."
for i in $(seq 1 120); do
    if curl -sf http://127.0.0.1:3001/ 2>/dev/null; then
        bashio::log.info "Uptime Kuma is ready (${i}s)"
        printf '\n' >&3
        wait $APP_PID
        exit $?
    fi
    sleep 1
done
bashio::log.error "Uptime Kuma failed to start within 120s"
kill $APP_PID 2>/dev/null
exit 1
